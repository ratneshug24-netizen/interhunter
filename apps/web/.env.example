# ─── NextAuth Configuration ───
# Secret used to encrypt NextAuth session cookies
NEXTAUTH_SECRET=a_very_secret_key_change_me_in_production
# The canonical URL of the site (used for callbacks and redirects)
NEXTAUTH_URL=http://localhost:3000

# ─── API Connection ───
# The internal/external URL where the Express API is running
NEXT_PUBLIC_API_URL=http://localhost:4000/api
