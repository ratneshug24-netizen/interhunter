# ─── Database & Redis ───
# Connection string for PostgreSQL database
DATABASE_URL=postgresql://internhunter:internhunter_secret@localhost:5432/internhunter?schema=public
# Host and port for BullMQ Redis broker
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API Keys ───
# Crunchbase API Key for funding and company info
CRUNCHBASE_API_KEY=your_crunchbase_key
# ProductHunt GraphQL API Key
PRODUCTHUNT_API_KEY=your_producthunt_key
# Hunter.io API Key for finding founder emails
HUNTER_API_KEY=your_hunter_key
# BuiltWith API Key for technology stack lookup
BUILTWITH_API_KEY=your_builtwith_key
# LinkedIn API Key for checking job postings
LINKEDIN_API_KEY=your_linkedin_key
# Anthropic API Key for generating personalized cold emails (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_key

# ─── Email Dispatch (SMTP or SES) ───
# Use AWS SES if true, otherwise use standard SMTP
USE_SES=false
# Standard SMTP configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
# AWS SES configuration (if USE_SES=true)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# ─── Application Server ───
# Allowed origins for CORS (e.g. Next.js frontend)
CORS_ORIGIN=http://localhost:3000
# Express server port
PORT=4000
# Node environment (development, production)
NODE_ENV=development

# ─── Authentication ───
# Used by NextAuth to verify API requests and hash tokens
NEXTAUTH_SECRET=a_very_secret_key_change_me_in_production
