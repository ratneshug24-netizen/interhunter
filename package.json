{
  "name": "internhunter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -w apps/api run dev",
    "dev:web": "npm -w apps/web run dev",
    "build": "npm run build:types && npm run build:api && npm run build:web",
    "build:types": "npm -w packages/types run build",
    "build:api": "npm -w apps/api run build && echo 'Prisma target updated v2'",
    "build:web": "npm -w apps/web run build",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm -w apps/api run db:generate",
    "db:migrate": "npm -w apps/api run db:migrate",
    "db:push": "npm -w apps/api run db:push",
    "db:studio": "npm -w apps/api run db:studio",
    "db:seed": "npm -w apps/api run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
