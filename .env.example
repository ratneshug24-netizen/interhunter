# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://internhunter:internhunter_secret@localhost:5432/internhunter?schema=public

# ─── Redis ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API Server ─────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── LLM APIs ──────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Email / SMTP ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
USE_SES=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Aggregator APIs ───────────────────────
CRUNCHBASE_API_KEY=your-crunchbase-api-key-here
PRODUCTHUNT_API_KEY=your-producthunt-developer-token-here
LINKEDIN_API_KEY=your-linkedin-api-key-here

# ─── Enrichment APIs ──────────────────────
BUILTWITH_API_KEY=your-builtwith-api-key-here
HUNTER_API_KEY=your-hunter-io-api-key-here

# ─── Next.js ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
